# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# --- Django ---
SECRET_KEY=generate-a-long-random-secret-key
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---
DB_NAME=atelier
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
# Or a single URL (overrides the DB_* vars):
# DATABASE_URL=postgres://user:password@host:5432/atelier

# --- JWT ---
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# --- Email (order & low-stock notifications) ---
# Leave EMAIL_BACKEND on the console backend for local dev (prints emails to logs).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
ADMIN_EMAIL=
SITE_URL=http://localhost:8000
LOW_STOCK_THRESHOLD=10

# --- M-Pesa (Safaricom Daraja) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain/api/payments/mpesa/callback/
MPESA_API_URL=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest
MPESA_AUTH_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials

# --- Chatbot (RAG) ---
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=atelier
